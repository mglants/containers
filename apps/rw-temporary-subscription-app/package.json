{
  "name": "rw-temporary-subscription-app",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server & npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server",
    "docker:build": "docker build -t rw-temporary-subscription-app .",
    "docker:run": "docker run --rm --init -p 3001:3001 --env-file .env -v rw-temp-subscription-data:/app/server/data rw-temporary-subscription-app"
  }
}
